# ── SMTP – Microsoft 365 ──────────────────────────────────────────────────────
# Zkopíruj jako .env.local a doplň hodnoty
# Na Vercelu přidej v: Project Settings → Environment Variables

# E-mail účet ze kterého se odesílá (musí mít povolený SMTP AUTH v M365 admin centru)
SMTP_USER=vladimir.fort@bidli.cz

# Heslo k Microsoft 365 účtu (nebo App Password pokud máte MFA)
SMTP_PASS=

# Kam chodit poptávky
MAIL_TO=lukas.hrncir@bidli.cz
